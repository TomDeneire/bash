#!/bin/bash
set -euo pipefail

SCRIPT_DIR="$(dirname "$(readlink -f "$0")")"
CURRENT_DATE=$(date +"%F")
PREVIOUS_DATE=$(cat "$SCRIPT_DIR/lastupdate.txt" 2>/dev/null || echo "")

if [ "$PREVIOUS_DATE" != "$CURRENT_DATE" ]; then
    if ping -c1 -W2 google.com &>/dev/null; then
        sudo apt-get update && sudo apt-get upgrade -y && sudo apt clean -y
        hop backup && date +"%F" > "$SCRIPT_DIR/lastupdate.txt"
    else
        echo "No internet connection. Cannot perform full update."
    fi

    # clean up files older than 30 days
    for dir in "$HOME/Downloads" "$HOME/.local/share/Trash" "$HOME/tmp"; do
        [ -d "$dir" ] && find "$dir" -mindepth 1 -mtime +30 -delete 2>/dev/null
    done

    # remove old docker containers
    docker container prune -f

    df -h
else
    echo "No update needed"
fi

neofetch
